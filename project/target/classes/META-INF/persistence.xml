<?xml version="1.0" encoding="UTF-8"?>
<persistence xmlns="https://jakarta.ee/xml/ns/persistence"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xsi:schemaLocation="https://jakarta.ee/xml/ns/persistence
                                 https://jakarta.ee/xml/ns/persistence/persistence_3_0.xsd"
             version="3.0">

    <!-- ExamPU — Mapea a exam_db (PostgreSQL :5432) -->
    <persistence-unit name="ExamPU" transaction-type="JTA">
        <jta-data-source>java:/ExamDS</jta-data-source>

        <class>co.universidad.taller.model.ExamSubmission</class>
        <class>co.universidad.taller.model.Entities.SagaExecution</class>

        <!--
         CRÍTICO: excluir clases no listadas para que Hibernate no escanee
         Student/Grade y las busque en exam_db donde no existen.
        -->
        <exclude-unlisted-classes>true</exclude-unlisted-classes>

        <properties>
            <!--
             "update": Hibernate crea/actualiza las tablas automáticamente.
             Evita el error de validate cuando las tablas aún no existen.
            -->
            <property name="jakarta.persistence.schema-generation.database.action"
                      value="update"/>
            <property name="hibernate.dialect"
                      value="org.hibernate.dialect.PostgreSQLDialect"/>
            <property name="hibernate.show_sql" value="true"/>
            <property name="hibernate.format_sql" value="true"/>
            <property name="hibernate.cache.use_second_level_cache" value="false"/>
            <property name="hibernate.jdbc.batch_size" value="25"/>
        </properties>
    </persistence-unit>

    <!-- StudentPU — Mapea a student_db (PostgreSQL :5433) -->
    <persistence-unit name="StudentPU" transaction-type="JTA">
        <jta-data-source>java:/StudentDS</jta-data-source>

        <class>co.universidad.taller.model.Entities.Student</class>
        <class>co.universidad.taller.model.Entities.Grade</class>

        <!-- CRÍTICO: excluir clases no listadas -->
        <exclude-unlisted-classes>true</exclude-unlisted-classes>

        <properties>
            <property name="jakarta.persistence.schema-generation.database.action"
                      value="update"/>
            <property name="hibernate.dialect"
                      value="org.hibernate.dialect.PostgreSQLDialect"/>
            <property name="hibernate.show_sql" value="true"/>
            <property name="hibernate.format_sql" value="true"/>
            <property name="hibernate.cache.use_second_level_cache" value="false"/>
            <property name="hibernate.jdbc.batch_size" value="25"/>
        </properties>
    </persistence-unit>

</persistence>